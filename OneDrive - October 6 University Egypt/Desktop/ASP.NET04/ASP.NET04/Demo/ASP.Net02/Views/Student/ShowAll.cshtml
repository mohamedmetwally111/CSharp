@model List<Student>
@{
    ViewData["Title"] = "ShowAll";
}

<h1>ShowAll</h1>

<a href="/Student/Add" class="btn btn-success" >New</a>

<table class="table table-hover">

    <tr>
        <th>Name</th>
        <th>Age</th>
        <th>Id</th>
        <th>DeprtmentId</th>
        <th></th>
        <th></th>

    </tr>

    @foreach(var item in Model)
    {
        <tr>
            <td>@item.Name</td>
            <td>@item.Age</td>
            <td>@item.Id</td>
            <td>@item.DepartmentId</td>
            <td><a href="/Student/Edit/@item.Id">Edit</a></td>
            <td><a href="/Student/Delete/@item.Id">Delete</a></td>
        </tr>
    }

</table>
